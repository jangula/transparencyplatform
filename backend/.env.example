# Database Configuration
DATABASE_URL=postgresql://nstp_user:nstp_password@localhost:5432/transparency_platform

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Security Settings
SECRET_KEY=your-secret-key-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
MFA_ISSUER_NAME=NSTP

# Password Policy
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGITS=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_EXPIRY_DAYS=90
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=30

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=eu-west-1
AWS_S3_BUCKET=nstp-documents
USE_S3=true  # Set to false to use local file storage

# Email Configuration (SendGrid)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key
SMTP_TLS=true
EMAIL_FROM=noreply@strategyprogress.gov.na
EMAIL_FROM_NAME=National Strategy Platform
EMAIL_REPLY_TO=support@strategyprogress.gov.na

# Or use Gmail SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Application Settings
APP_NAME=National Strategy Transparency Platform
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
ALLOWED_HOSTS=*
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# File Upload Settings
MAX_UPLOAD_SIZE=52428800  # 50MB in bytes
ALLOWED_DOCUMENT_EXTENSIONS=.pdf
ALLOWED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png
UPLOAD_DIR=./uploads

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_ENABLED=true

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Session Configuration
SESSION_TIMEOUT_MINUTES=30
MAX_CONCURRENT_SESSIONS=2

# Notification Settings
SEND_EMAIL_NOTIFICATIONS=true
UPDATE_REMINDER_DAYS=7
OVERDUE_ESCALATION_DAYS=7
QUESTION_RESPONSE_DAYS=14

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
LOG_ROTATION=1 week
LOG_RETENTION=90 days

# Backup Settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # 2 AM daily
BACKUP_RETENTION_DAYS=30

# Monitoring
SENTRY_DSN=  # Optional: Sentry error tracking
ENABLE_METRICS=true
METRICS_PORT=9090

# Features Flags (for phased rollout)
ENABLE_Q_AND_A=true
ENABLE_FILE_UPLOADS=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_MFA=true
REQUIRE_MFA_FOR_ADMINS=true
